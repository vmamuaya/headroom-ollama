# Headroom proxy environment — persistent location (was /tmp, moved 2026-06-29)
# Edit OLLAMA_API_KEY here, then: systemctl --user restart headroom-proxy.service
OLLAMA_API_KEY=***your-ollama-cloud-api-key-here***
OLLAMA_BASE_URL=https://ollama.com/v1

# Headroom 0.27 backend selection — defaults to Anthropic otherwise
HEADROOM_BACKEND=litellm-openai

# OpenAI-compatible passthrough target — Ollama Cloud is OpenAI-compatible at /v1
OPENAI_TARGET_API_URL=https://ollama.com/v1

# Kompress behavior (replaces FORCE_KOMPRESS/COMPRESS_USER_MESSAGES/MIN_TOKENS — those
# were 0.2.x names; 0.27 uses CLI flags but these env equivalents are documented)
HEADROOM_TARGET_RATIO=0.4

# Tier-3 web extraction cache (survives venv nukes)
CLOAKBROWSER_CACHE_DIR=/home/victor/.cache/cloakbrowser

# Alias for any-llm ollama provider — its provider code reads OPENAI_API_KEY
# as the auth fallback (Ollama Cloud is OpenAI-compatible at /v1)
OPENAI_API_KEY=***your-ollama-cloud-api-key-here***

# CRITICAL: litellm's openai/ provider reads OPENAI_BASE_URL to override the
# default api.openai.com endpoint. Headroom's LiteLLMBackend.send_message() does
# NOT pass api_base to acompletion, so this env var is the only way to redirect
# litellm to Ollama Cloud when HEADROOM_BACKEND=litellm-openai.
OPENAI_BASE_URL=https://ollama.com/v1